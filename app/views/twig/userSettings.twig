{% extends "base.twig" %}

{% block title %}Správa uživatelů{% endblock %}
{% block content %}

    <h1 class="mb-3">Správa uživatelů</h1>

    <div class="table-wrapper">
        <table class="table table-bordered align-middle user-settings-table">
            <thead class="table-dark">
            <tr>
                <th>Login</th>
                <th>Jméno</th>
                <th>Email</th>
                <th>Role</th>
                <th>Stav</th>
                <th>Akce</th>
            </tr>
            </thead>
            <tbody>
            {% for u in users %}
                <tr data-id="{{ u.id_user }}">
                    <td>{{ u.username }}</td>
                    <td>{{ u.name }}</td>
                    <td>{{ u.email }}</td>

                    <td>
{#                         Hierarchie rolí - aby mohli upravovat jen ty pod sebou#}

                        {% if u.can_edit_role %}
                            <select class="form-select form-select-sm role-select">
                                {% if user.roles_id == 1 %}
                                    <option value="2" {% if u.roles_id == 2 %}selected{% endif %}>Admin</option>
                                {% endif %}
                                <option value="3" {% if u.roles_id == 3 %}selected{% endif %}>Recenzent</option>
                                <option value="4" {% if u.roles_id == 4 %}selected{% endif %}>Autor</option>
                            </select>

                        {% else %}
                            <strong>{{ u.role_name }}</strong>
                        {% endif %}
                    </td>

                    {# 🔹 STAV #}
                    <td class="status-cell text-center">
                        {% if u.blocked %}
                            <span class="badge bg-danger">Zablokován</span>
                        {% else %}
                            <span class="badge bg-success">Aktivní</span>
                        {% endif %}
                    </td>

                    <td class="actions-cell text-center">

                        {# BLOKACE / ODBLOKACE #}
                        {% if user.roles_id <= 2 and u.roles_id > user.roles_id %}
                            {% if u.blocked %}
                                <button class="btn btn-sm btn-outline-success unblock-btn">Odblokovat</button>
                            {% else %}
                                <button class="btn btn-sm btn-outline-warning block-btn">Zakázat</button>
                            {% endif %}
                        {% endif %}

                        {# SMAZÁNÍ #}
                        {% if user.roles_id <= 2 and u.roles_id > user.roles_id %}
                            <button class="btn btn-sm btn-danger delete-btn ms-1">Smazat</button>
                        {% endif %}

                    </td>


{#                    <td class="text-center">#}
{#                        {% if u.can_unblock %}#}
{#                            <button class="btn btn-sm btn-outline-success unblock-btn">Odblokovat</button>#}
{#                        {% elseif u.can_block %}#}
{#                            <button class="btn btn-sm btn-outline-danger block-btn">Zakázat</button>#}
{#                        {% else %}#}
{#                            –#}
{#                        {% endif %}#}
{#                    </td>#}

                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
