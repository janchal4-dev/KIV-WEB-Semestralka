{% extends "base.twig" %}

{% block title %}Správa uživatelů{% endblock %}
{% block content %}

    <h1 class="mb-3">Správa uživatelů</h1>

    <div class="table-wrapper">
        <table class="table table-bordered align-middle">
            <thead class="table-dark">
            <tr>
                <th>Login</th>
                <th>Jméno</th>
                <th>Email</th>
                <th>Role</th>
                <th>Stav</th>
                <th>Akce</th>
            </tr>
            </thead>
            <tbody>
            {% for u in users %}
                <tr>
                    <td>{{ u.username }}</td>
                    <td>{{ u.name }}</td>
                    <td>{{ u.email }}</td>

                    <td>
                        {# Hierarchie rolí - aby mohli upravovat jen ty pod sebou #}
                        {% if user.roles_id == 1 and u.role_name != 'SuperAdmin' %}
                            {# SuperAdmin → může měnit kohokoliv kromě jiného SuperAdmina #}
                            <select class="form-select form-select-sm">
                                <option {% if u.role_name == 'Admin' %}selected{% endif %}>Admin</option>
                                <option {% if u.role_name == 'Recenzent' %}selected{% endif %}>Recenzent</option>
                                <option {% if u.role_name == 'Autor' %}selected{% endif %}>Autor</option>
                            </select>

                        {% elseif user.roles_id == 2 and u.role_name not in ['SuperAdmin', 'Admin'] %}
                            {# Admin → může měnit pouze Recenzenta a Autora #}
                            <select class="form-select form-select-sm">
                                <option {% if u.role_name == 'Recenzent' %}selected{% endif %}>Recenzent</option>
                                <option {% if u.role_name == 'Autor' %}selected{% endif %}>Autor</option>
                            </select>

                        {% else %}
                            {# Ostatní (nebo sebe) pouze vidí roli #}
                            <strong>{{ u.role_name }}</strong>
                        {% endif %}

                    </td>

                    <td>

                        {% if u.blocked %}
                            <span class="badge bg-danger">Zablokován</span>
                        {% else %}
                            <span class="badge bg-success">Aktivní</span>
                        {% endif %}
                    </td>

                    <td>
                        {# Aby mohli blokovat jen ty pod sebou #}
                        {% set canBlock = false %}

                        {# 🦸 SuperAdmin může blokovat všechny kromě sebe #}
                        {% if user.roles_id == 1 and u.username != user.username %}
                            {% set canBlock = true %}
                        {% endif %}

                        {# 👨‍💼 Admin může blokovat jen Recenzenty a Autory, nikdy Admina/SuperAdmina #}
                        {% if user.roles_id == 2 and u.role_name in ['Recenzent', 'Autor'] %}
                            {% set canBlock = true %}
                        {% endif %}

                        {% if canBlock %}
                            <button class="btn btn-sm btn-outline-danger">Zakázat</button>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
