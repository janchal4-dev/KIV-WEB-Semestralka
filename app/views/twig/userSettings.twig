{% extends "base.twig" %}

{% block title %}Správa uživatelů{% endblock %}
{% block content %}

    <h1 class="mb-3">Správa uživatelů</h1>

    <div class="table-wrapper">
        <table class="table table-bordered align-middle user-settings-table">
            <thead class="table-dark">
            <tr>
                <th>Login</th>
                <th>Jméno</th>
                <th>Email</th>
                <th>Role</th>
                <th>Stav</th>
                <th>Akce</th>
            </tr>
            </thead>
            <tbody>
            {% for u in users %}
                <tr data-id="{{ u.id_user }}">
                    <td>{{ u.username }}</td>
                    <td>{{ u.name }}</td>
                    <td>{{ u.email }}</td>

                    <td>
                        {# Hierarchie rolí - aby mohli upravovat jen ty pod sebou #}
                        {% if user.roles_id == 1 and u.role_name != 'SuperAdmin' %}
                            <select class="form-select form-select-sm role-select">
                                <option value="2" {% if u.role_name == 'Admin' %}selected{% endif %}>Admin</option>
                                <option value="3" {% if u.role_name == 'Recenzent' %}selected{% endif %}>Recenzent</option>
                                <option value="4" {% if u.role_name == 'Autor' %}selected{% endif %}>Autor</option>
                            </select>


                        {% elseif user.roles_id == 2 and u.role_name not in ['SuperAdmin', 'Admin'] %}
                            <select class="form-select form-select-sm role-select">
                                <option value="3" {% if u.role_name == 'Recenzent' %}selected{% endif %}>Recenzent</option>
                                <option value="4" {% if u.role_name == 'Autor' %}selected{% endif %}>Autor</option>
                            </select>


                        {% else %}
                            <strong>{{ u.role_name }}</strong>
                        {% endif %}
                    </td>

                    {# 🔹 STAV #}
                    <td class="status-cell text-center">
                        {% if u.blocked %}
                            <span class="badge bg-danger">Zablokován</span>
                        {% else %}
                            <span class="badge bg-success">Aktivní</span>
                        {% endif %}
                    </td>

                    {# 🔹 AKCE #}
                    <td class="actions-cell text-center">
                        {% if u.blocked %}
                            {% if (user.roles_id <= 2) and (u.id_user != user.id_user) %}
                                <button class="btn btn-sm btn-outline-success unblock-btn">
                                    Odblokovat
                                </button>
                            {% endif %}
                        {% else %}
                            {% if ((user.roles_id == 1 and u.roles_id != 1) or
                                (user.roles_id == 2 and u.roles_id > 2))
                                and (u.id_user != user.id_user) %}
                                <button class="btn btn-sm btn-outline-danger block-btn">
                                    Zakázat
                                </button>
                            {% endif %}
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
