{% extends "base.twig" %}

{% block title %}Recenze{% endblock %}
{% block content %}
    <h1 class="mb-4">Napsat recenzi</h1>

    <form id="reviewForm" class="review-form">
        <input type="hidden" id="post_id" value="{{ post.id_post }}">

        <div class="mb-3">
            <label class="form-label">Kvalita</label>
            <div class="rating" data-field="rev_quality"></div>
        </div>

        <div class="mb-3">
            <label class="form-label">Jazyk</label>
            <div class="rating" data-field="rev_language"></div>
        </div>

        <div class="mb-3">
            <label class="form-label">Originalita</label>
            <div class="rating" data-field="rev_originality"></div>
        </div>

        <div class="mb-3">
            <label class="form-label">Komentář</label>
            <textarea id="reviewComment"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Odeslat recenzi</button>
    </form>

    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
{% endblock %}
