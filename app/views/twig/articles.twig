{% extends "base.twig" %}
{% block title %}Články{% endblock %}

{% block content %}

    <h1 id="headlineAnimation" class="mb-4 fade-type">Články</h1>
    {% for p in posts %}
        <div class="card mb-4 article-card">
        <div class="card-body">

                <h3>{{ p.name }}</h3>
                <p><strong>Autor:</strong> {{ p.author_name }}</p>

                <div class="row mt-3">

                    {# ------- PDF VIEWER VLEVO ------- #}
                    <div class="col-md-8">
                        <iframe
                                class="pdf-frame"
                                src="{{ app_base }}/uploads/{{ p.file_path }}"
                                style="width:100%; height:600px; border:0;">
                        </iframe>
                    </div>


                    {# ------- RECENZE VPRAVO ------- #}
                    <div class="col-md-4">
                        <h5>Recenze</h5>

                        {% if p.reviews is empty %}
                            <p class="text-muted">Tento článek zatím nemá žádné recenze.</p>
                        {% endif %}

                        {% for r in p.reviews %}
                            <div class="border p-2 rounded mb-3 bg-light">
                                <strong>Recenzent:</strong> {{ r.reviewer_name }}<br>

                                <strong>Kvalita:</strong>
                                {% if r.rev_quality > 0 %}
                                    {% for i in 1..r.rev_quality %}<span class="text-warning">★</span>{% endfor %}
                                {% endif %}
                                {% set emptyStars = 5 - (r.rev_quality) %}
                                {% if emptyStars > 0 %}
                                    {% for i in 1..emptyStars %}
                                        <span class="text-muted">☆</span>
                                    {% endfor %}
                                {% endif %}

                                <br>

                                <strong>Jazyk:</strong>
                                {% if r.rev_language > 0 %}
                                    {% for i in 1..r.rev_language %}<span class="text-warning">★</span>{% endfor %}
                                {% endif %}
                                {% set emptyStars = 5 - (r.rev_language) %}
                                {% if emptyStars > 0 %}
                                    {% for i in 1..emptyStars %}
                                        <span class="text-muted">☆</span>
                                    {% endfor %}
                                {% endif %}
                                <br>

                                <strong>Originalita:</strong>
                                {% if r.rev_originality > 0 %}
                                    {% for i in 1..r.rev_originality %}<span class="text-warning">★</span>{% endfor %}
                                {% endif %}
                                {% set emptyStars = 5 - (r.rev_originality) %}
                                {% if emptyStars > 0 %}
                                    {% for i in 1..emptyStars %}
                                        <span class="text-muted">☆</span>
                                    {% endfor %}
                                {% endif %}
                                <br>

                                <strong>Komentář:</strong>
                                <div class="mt-1">
                                    {% autoescape false %}{{ r.comment }}{% endautoescape %}
                                </div>
                            </div>

                        {% endfor %}
                    </div>

                </div> <!-- /row -->

            </div>
        </div>
    {% endfor %}

{% endblock %}
