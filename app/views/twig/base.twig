{# app/views/twig/base.twig #}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Konference{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="{{ app_base }}/style.css" rel="stylesheet">
</head>
<body>

<header class="bg-dark position-relative" style="z-index:1000;">
    <nav class="navbar navbar-expand-lg navbar-dark container">
        <a class="navbar-brand" href="index.php"><span>Konference</span></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link {{ currentPage == 'home' ? 'active fw-bold' }}" href="?page=home">Domů</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentPage == 'articles' ? 'active fw-bold' }}" href="?page=articles">Články</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentPage == 'program' ? 'active fw-bold' }}" href="?page=program">Program</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentPage == 'upload' ? 'active fw-bold' }}" href="?page=upload">Nahrát článek</a>
                </li>
            </ul>

            <ul class="navbar-nav">

                {% if not user %}
                    <!-- Není přihlášen -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {{ currentPage == 'login' ? 'active fw-bold' }}"
                           href="#" role="button" data-bs-toggle="dropdown">
                            Login
                        </a>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width:260px;">
                            <form method="post" action="?page=login">
                                <div class="mb-3">
                                    <input type="text" name="username" class="form-control" placeholder="Login" autocomplete="username">
                                </div>
                                <div class="mb-3">
                                    <input type="password" name="password" class="form-control" placeholder="Heslo" autocomplete="current-password">
                                </div>
                                <button type="submit" class="btn btn-primary w-100">Přihlásit</button>
                            </form>
                        </div>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link {{ currentPage == 'registration' ? 'active fw-bold' }}" href="?page=registration">Registrace</a>
                    </li>

                {% else %}
                    <!-- ✅ Přihlášen -->
                    <li class="nav-item">
            <span class="navbar-text me-2">
                👤 {{ user.name }}
            </span>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-danger fw-bold" href="?page=logout">Logout</a>
                    </li>
                {% endif %}
            </ul>



        </div>
    </nav>
</header>
<main class="container mt-4">
    {% if session.error %}
        <div class="alert alert-danger">{{ session.error }}</div>
    {% endif %}




    {% block content %}{% endblock %}
</main>

<footer class="text-center mt-5">
    © 2025 Janchal4
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ app_base }}/script.js"></script>
</body>
</html>
