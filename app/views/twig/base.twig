{# app/views/twig/base.twig #}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Konference{% endblock %}</title>
{#    Bootstrap #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
{#    Bootstrap ikony#}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <link href="{{ app_base }}/app/style/style.css" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">


<header class="bg-dark position-relative" style="z-index:1000;">
    <nav class="navbar navbar-expand-lg navbar-dark container">
        <a class="navbar-brand" href="index.php"><span>Konference</span></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link {{ currentPage == 'home' ? 'active fw-bold' }}" href="?page=home">Domů</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentPage == 'articles' ? 'active fw-bold' }}" href="?page=articles">Články</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentPage == 'program' ? 'active fw-bold' }}" href="?page=program">Program</a>
                </li>
                {# Nahrát článek jen pro autory #}
                {% if user.roles_id == 4 %}
                    <li class="nav-item">
                        <a class="nav-link {{ currentPage == 'upload' ? 'active fw-bold' }}" href="?page=upload">
                            Nahrát článek
                        </a>
                    </li>
                {% endif %}

                {# Úprava recenzí jen pro recenzenty #}
                {% if user and user.roles_id == 3 %}
                    <li class="nav-item">
                        <a class="nav-link {{ currentPage == 'reviewList' ? 'active fw-bold' }}" href="?page=reviewList">
                            📝 Úprava recenzí
                        </a>
                    </li>
                {% endif %}

                {# Správa článků jen pro (super)adminy #}
                {% if user and user.roles_id <= 2 %}
                    <li class="nav-item">
                        <a class="nav-link {{ currentPage == 'managePosts' ? 'active fw-bold' }}"
                           href="?page=managePosts">Správa článků</a>
                    </li>
                {% endif %}

                {# Správa článků jen pro (super)adminy #}
                {% if user and user.roles_id <= 2 %}
                    <li class="nav-item">
                        <a class="nav-link {{ currentPage == 'manageReviews' ? 'active fw-bold' }}"
                           href="?page=manageReviews">Správa recenzí</a>
                    </li>
                {% endif %}
                {# Autor vidí stav svého článku #}
                {% if user.roles_id == 4 %}
                    <li class="nav-item">
                        <a class="nav-link {{ currentPage == 'myPosts' ? 'active fw-bold' }}"
                           href="?page=myPosts">
                            Moje články
                        </a>
                    </li>
                {% endif %}



            </ul>

            <ul class="navbar-nav">

                {% if not user %}
                    <!-- Není přihlášen -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {{ currentPage == 'login' ? 'active fw-bold' }}"
                           href="#" role="button" data-bs-toggle="dropdown">
                            Login
                        </a>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width:260px;">
                            <form method="post" action="?page=login">
                                <div class="mb-3">
                                    <input type="text" name="username" class="form-control" placeholder="Login" autocomplete="username">
                                </div>
                                <div class="mb-3">
                                    <input type="password" name="password" class="form-control" placeholder="Heslo" autocomplete="current-password">
                                </div>
                                <button type="submit" class="btn btn-primary w-100">Přihlásit</button>
                            </form>
                        </div>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link {{ currentPage == 'registration' ? 'active fw-bold' }}" href="?page=registration">Registrace</a>
                    </li>

                {% else %}
                    {#              zobrazení loginu jména#}
                    <li class="nav-item">
                    <li class="nav-item d-flex align-items-center">
    <span class="navbar-text me-3 d-flex align-items-center">
        <i class="bi bi-person-circle me-1 text-light" style="font-size: 1.3rem;"></i>
        {{user.username }}
    </span>
                    </li>
                {% if user and (user.roles_id == 1 or user.roles_id == 2)   %}
                    <li class="nav-item d-flex align-items-center">
                        <a class="nav-link accountLink {{ currentPage == 'userSettings' ? 'active fw-bold' }}"
                           href="?page=userSettings">Správa uživatelů</a>
                    </li>
                    {% endif  %}
{#                logout#}
                    <li class="nav-item d-flex align-items-center">
                        <a class="nav-link text-danger fw-bold" href="?page=logout">Logout</a>
                    </li>
                {% endif %}
            </ul>



        </div>
    </nav>
</header>
<main class="container mt-4">
    {% if session.error %}
        <div class="alert alert-danger">{{ session.error }}</div>
    {% endif %}




    {% block content %}{% endblock %}
</main>

<footer class="mt-auto text-center py-3 bg-dark text-white">
    © 2025 Janchal4
</footer>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ app_base }}/app/script/script.js"></script>
<script src="https://mozilla.github.io/pdf.js/build/pdf.js"></script>

</body>
</html>
