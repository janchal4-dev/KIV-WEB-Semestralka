{% extends "base.twig" %}

{% block title %}Úprava recenzí{% endblock %}

{% block content %}
    <h1 class="mb-3">📝 Úprava recenzí</h1>

    <div class="table-wrapper">
        <table class="table table-striped">
            <thead>
            <tr>
                <th>Název článku</th>
                <th>Autor</th>
                <th>Datum nahrání</th>
                <th>Akce</th>
            </tr>
            </thead>
            <tbody>
            {% for post in posts %}
                <tr>
                    <td>{{ post.title }}</td>          {# alias z SQL #}
                    <td>{{ post.author_name }}</td>    {# alias z SQL #}
                    <td>{{ post.date_uploaded|date("d.m.Y H:i") }}</td>
                    <td>
                        {% if r.published == 2 %}
                            <span class="badge bg-success">Schváleno – nelze upravit</span>
                        {% else %}
                            <a href="?page=review&id={{ post.id_post }}" class="btn btn-sm btn-outline-primary">
                                ✏️ Upravit / napsat recenzi
                            </a>

                        {% endif %}

                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">
                        Žádné články k recenzi.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <h2 class="mt-4">Moje recenze</h2>

    {% for r in reviews %}
        <div class="card p-3 mb-2">
            <strong>Článek:</strong> {{ r.post_name }}<br>
            <strong>Stav:</strong>
            {% if r.published == 0 %}
                <span class="badge bg-secondary">Čeká na schválení</span>
            {% elseif r.published == 1 %}
                <span class="badge bg-danger">Zamítnuto</span>
            {% elseif r.published == 2 %}
                <span class="badge bg-success">Schváleno</span>
            {% endif %}

        </div>
    {% endfor %}

{% endblock %}
